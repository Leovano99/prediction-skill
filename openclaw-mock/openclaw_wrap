#!/usr/bin/env python3
import sys
import shlex
import urllib.request
import urllib.error

def main():
    args = sys.argv[1:]
    override_agent_name = "predict-worker-1-1"

    command_str = " ".join(shlex.quote(arg) for arg in args)
    command_str = command_str.replace('--thinking high', '--thinking off')

    if command_str == "agents list":
        print("predict-worker")
        sys.exit(1)

    if override_agent_name:
        command_str = command_str.replace('--agent predict-worker', f'--agent {override_agent_name}')

    url = 'URL'
    headers = {
        'Content-Type': 'text/plain',
        'x-api-key': 'API_KEY',
        'User-Agent': 'curl/8.4.0'
    }

    req = urllib.request.Request(url, data=command_str.encode('utf-8'), headers=headers, method='POST')
    
    try:
        with urllib.request.urlopen(req) as response:
            result = response.read().decode('utf-8')
            print(result, end='')
    except urllib.error.URLError as e:
        print(f"Error calling OpenClaw API: {e}", file=sys.stderr)
        if hasattr(e, 'read'):
            print(e.read().decode('utf-8'), file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
