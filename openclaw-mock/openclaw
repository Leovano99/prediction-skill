#!/usr/bin/env python3
import sys
import os
import json
import urllib.request
import urllib.error

def main():
    args = sys.argv[1:]
    command_str = " ".join(args)

    if command_str == "agents list":
        print("predict-worker")
        sys.exit(1)

    if command_str == "sessions purge --agent predict-worker --yes":
        print("Sessions purged successfully.")
        sys.exit(1)

    # get api key from .env
    api_key = os.getenv("API_KEY")
    if not api_key:
        print("Error: API_KEY environment variable not set", file=sys.stderr)
        sys.exit(1)

    url = os.getenv("API_URL") or 'https://9router.leyon.my.id/v1/chat/completions'
    model = os.getenv("MODEL") or 'cx/gpt-5.4-mini'
    
    payload = {
        "model": model,
        "messages": [
            {"role": "system", "content": "you are acting as openclaw, so the response must be stdout like. if the prompt is about predict analytics, Write new, original analysis that reflects your own reading of mentioned market (because you are a professional trader analysis with 30+ YoE)."},
            {"role": "user", "content": command_str}
        ],
        "temperature": 0.1,
        "stream": False
    }
    
    headers = {
        'Content-Type': 'application/json',
        'Authorization': f'Bearer {api_key}',
        'User-Agent': 'curl/8.4.0'
    }

    req = urllib.request.Request(url, data=json.dumps(payload).encode('utf-8'), headers=headers, method='POST')
    
    try:
        with urllib.request.urlopen(req) as response:
            response_data = response.read().decode('utf-8')
            result = json.loads(response_data)
            content = result.get('choices', [{}])[0].get('message', {}).get('content', '')
            print(content, end='')
    except urllib.error.URLError as e:
        print(f"Error calling DeepSeek API: {e}", file=sys.stderr)
        if hasattr(e, 'read'):
            print(e.read().decode('utf-8'), file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()